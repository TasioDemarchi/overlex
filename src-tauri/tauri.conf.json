{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OverLex",
  "version": "0.1.0",
  "identifier": "com.overlex.app",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OverLex Settings",
        "width": 600,
        "height": 500,
        "resizable": true,
        "visible": false,
        "center": true,
        "url": "settings/index.html"
      },
      {
        "label": "freeze",
        "title": "Freeze",
        "fullscreen": true,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": false,
        "visible": false,
        "skipTaskbar": true,
        "devtools": true,
        "url": "freeze/index.html"
      },
      {
        "label": "result",
        "title": "Result",
        "width": 400,
        "height": 300,
        "minHeight": 150,
        "maxHeight": 600,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": true,
        "url": "result/index.html"
      },
      {
        "label": "write",
        "title": "Write",
        "width": 420,
        "height": 300,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "visible": false,
        "resizable": true,
        "skipTaskbar": true,
        "url": "write/index.html"
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https://*.googleapis.com https://libretranslate.com https://*.libretranslate.com https://api.mymemory.translated.net; font-src 'self'; frame-src 'none'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "both",
        "languages": ["English", "Spanish"]
      }
    }
  }
}