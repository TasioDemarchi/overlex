{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OverLex",
  "version": "0.1.0",
  "identifier": "com.overlex.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OverLex Settings",
        "width": 600,
        "height": 500,
        "resizable": true,
        "visible": false,
        "center": true,
        "url": "settings/index.html"
      },
      {
        "label": "freeze",
        "title": "Freeze",
        "fullscreen": true,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "url": "freeze/index.html"
      },
      {
        "label": "result",
        "title": "Result",
        "width": 400,
        "height": 150,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false,
        "url": "result/index.html"
      },
      {
        "label": "write",
        "title": "Write",
        "width": 350,
        "height": 80,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "resizable": false,
        "url": "write/index.html"
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "both",
        "languages": ["English", "Spanish"]
      }
    }
  }
}